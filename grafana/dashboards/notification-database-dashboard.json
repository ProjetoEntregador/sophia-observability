        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, max by (query_preview) (pg_stat_statements_io_time_total_io_time{service=\"notification\", datname=\"sophia_db\"}))",
          "legendFormat": "{{query_preview}}",
