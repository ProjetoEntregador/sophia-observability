        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Transactions Commit / Rollback",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(rate(pg_stat_database_xact_commit{service=\"notification\", datname=\"sophia_db\"}[1m]))",
          "legendFormat": "commit",
          "refId": "A"
        },
        {
          "expr": "max(rate(pg_stat_database_xact_rollback{service=\"notification\", datname=\"sophia_db\"}[1m]))",
          "legendFormat": "rollback",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 24
      }
    },
    {
      "id": 14,
      "type": "barchart",
      "title": "Top Queries by Total Execution Time",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, max by (query_preview) (pg_stat_statements_top_total_time_total_exec_time{service=\"notification\", datname=\"sophia_db\"}))",
          "legendFormat": "{{query_preview}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
