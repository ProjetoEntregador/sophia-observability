    {
      "id": 19,
      "type": "logs",
      "title": "PostgreSQL Logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{service=\"notification\", component=\"postgres\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showControls": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
